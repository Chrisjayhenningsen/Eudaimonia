{
  "manifest_version": 3,
  "name": "Eudaimonia",
  "version": "0.1.0",
  "description": "Track your goals and earn tokens for aligned promotions",
  
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true
    }
  ],
  
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["Eudaimonia_logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
